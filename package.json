{
  "name": "monet",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "vite dev & pnpm dev:api & pnpm dev:worker & wait",
    "build": "turbo build",
    "typecheck": "echo 'root typecheck handled by turbo pipeline'",
    "lint": "echo 'root lint handled by turbo pipeline'",
    "test": "turbo test",
    "dev:api": "pnpm --filter @monet/api dev",
    "dev:worker": "pnpm --filter @monet/worker-node dev",
    "dev:web": "pnpm --filter @monet/web dev",
    "infra:up": "docker compose -f infra/docker-compose.yml up -d",
    "infra:down": "docker compose -f infra/docker-compose.yml down",
    "python:audio": "cd workers/python-audio && python -m uvicorn app:app --host 0.0.0.0 --port 8101",
    "python:ai": "cd workers/python-ai && python -m uvicorn app:app --host 0.0.0.0 --port 8102",
    "eval": "bash scripts/run-eval.sh",
    "eval:save": "bash scripts/run-eval.sh --save-baseline",
    "eval:list": "bash scripts/run-eval.sh --list",
    "eval:dialogue": "KMP_DUPLICATE_LIB_OK=TRUE python3 scripts/eval_dialogue.py",
    "eval:dialogue:save": "KMP_DUPLICATE_LIB_OK=TRUE python3 scripts/eval_dialogue.py --save-baseline",
    "eval:dialogue:list": "python3 scripts/eval_dialogue.py --list"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260703.1",
    "@google-cloud/vertexai": "^1.12.0",
    "@google/generative-ai": "^0.24.1",
    "@lovable.dev/vite-tanstack-config": "^2.6.5",
    "@radix-ui/react-accordion": "^1.2.15",
    "@radix-ui/react-alert-dialog": "^1.1.18",
    "@radix-ui/react-aspect-ratio": "^1.1.11",
    "@radix-ui/react-avatar": "^1.2.1",
    "@radix-ui/react-hover-card": "^1.1.18",
    "@radix-ui/react-menubar": "^1.1.19",
    "@radix-ui/react-navigation-menu": "^1.2.17",
    "@radix-ui/react-radio-group": "^1.4.2",
    "@radix-ui/react-separator": "^1.1.11",
    "@tanstack/react-query": "^5.101.2",
    "@types/bun": "^1.3.14",
    "@types/node": "^22.10.7",
    "cmdk": "^1.1.1",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "react-day-picker": "^10.0.1",
    "react-hook-form": "^7.80.0",
    "react-resizable-panels": "^4.12.0",
    "recharts": "^3.9.1",
    "sonner": "^2.0.7",
    "tsx": "^4.19.2",
    "turbo": "^2.3.3",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.7.3",
    "vaul": "^1.1.2",
    "vite": "8.1.3",
    "vitest": "^1.6.0"
  },
  "dependencies": {
    "@clerk/backend": "^1.21.0",
    "@clerk/react": "^6.12.5",
    "@paddle/paddle-js": "^1.6.4",
    "@remotion/cli": "^4.0.484",
    "@remotion/player": "^4.0.484",
    "@sentry/node": "^8.0.0",
    "aws4fetch": "^1.0.20",
    "ffmpeg": "^0.0.4",
    "fluent-ffmpeg": "^2.1.3",
    "openai": "^6.45.0",
    "remotion": "^4.0.484",
    "replicate": "^0.34.1"
  },
  "pnpm": {
    "overrides": {
      "react": "^19.0.0",
      "react-dom": "^19.0.0"
    }
  }
}
