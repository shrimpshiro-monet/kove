{
  "name": "monet",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "test": "turbo test",
    "dev:api": "pnpm --filter @monet/api dev",
    "dev:worker": "pnpm --filter @monet/worker-node dev",
    "dev:web": "pnpm --filter @monet/web dev",
    "infra:up": "docker compose -f infra/docker-compose.yml up -d",
    "infra:down": "docker compose -f infra/docker-compose.yml down",
    "python:audio": "cd workers/python-audio && python -m uvicorn app:app --host 0.0.0.0 --port 8101",
    "python:ai": "cd workers/python-ai && python -m uvicorn app:app --host 0.0.0.0 --port 8102"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^22.10.7",
    "tsx": "^4.19.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  },
  "dependencies": {
    "ffmpeg": "^0.0.4",
    "fluent-ffmpeg": "^2.1.3",
    "replicate": "^0.34.1"
  }
}
