NODE_ENV=development

REDIS_HOST=127.0.0.1
REDIS_PORT=6379

MONET_API_PORT=3000
PYTHON_AUDIO_URL=http://127.0.0.1:8101
PYTHON_AI_URL=http://127.0.0.1:8102

FFMPEG_PATH=ffmpeg
