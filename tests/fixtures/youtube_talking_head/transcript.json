  "sentences": [
    {
      "text": "Today I want to talk about how artificial intelligence is transforming video editing.",
      "start": 0.0,
      "end": 5.38
    },
    {
      "text": "The key insight is that good editing follows patterns we can measure and replicate.",
      "start": 6.86,
      "end": 11.48
    },
    {
      "text": "By analyzing reference edits we extract a style profile that captures pacing color and motion.",
      "start": 13.1,
      "end": 19.34
    },
    {
      "text": "Then we apply that profile to new footage automatically producing consistent results",
      "start": 20.26,
      "end": 26.06
    }
  ],
