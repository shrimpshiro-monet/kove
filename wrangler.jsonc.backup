{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "monet-ai-director",
	"compatibility_date": "2025-09-24",
	"compatibility_flags": [
		"nodejs_compat"
	],
	"main": "src/server.ts",
	"vars": {
		"ENVIRONMENT": "development"
	},
	"r2_buckets": [
		{
			"binding": "MONET_MEDIA",
			"bucket_name": "monet-media-dev",
			"preview_bucket_name": "monet-media-preview"
		},
		{
			"binding": "MONET_RENDERS",
			"bucket_name": "monet-renders-dev",
			"preview_bucket_name": "monet-renders-preview"
		}
	],
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "monet-db-dev",
			"database_id": "TO_BE_CREATED"
		}
	],
	"kv_namespaces": [
		{
			"binding": "MONET_KV",
			"id": "TO_BE_CREATED",
			"preview_id": "TO_BE_CREATED"
		}
	]
}