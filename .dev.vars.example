# Monet AI Director - Environment Variables
# Copy this to .dev.vars and fill in your credentials

# Option 1: Vertex AI via GCP (recommended - better rate limits)
GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=us-central1
# Optional model override (defaults to a non-2.5-flash model in code)
# VERTEX_GEMINI_MODEL=gemini-2.5-pro
# Optional: GCP service account credentials as JSON string
# GCP_CREDENTIALS={"type":"service_account",...}

# Option 2: Gemini API (free tier - 20 requests/day)
# GEMINI_API_KEY=your-gemini-api-key
# Optional model override for direct Gemini API usage
# GEMINI_MODEL=gemini-2.5-pro

# Optional: GCS Bucket for Vertex AI multimodal assets
GCS_BUCKET=your-gcs-bucket-name

# Environment
ENVIRONMENT=development

DIGITALOCEAN_API_KEY="doo_v1_cd505c829ff95904c49590ecdf6fe1d899fd472a468df64ab39ddbc32c7a6447"

# Clerk Authentication (optional — auth is bypassed if these are absent)
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Paddle Billing (v2) — Merchant of Record for global payments
# Get API keys from https://sandbox-vendors.paddle.com (sandbox) or https://vendors.paddle.com (production)
PADDLE_API_KEY=pdl_...
PADDLE_WEBHOOK_SECRET=...
PADDLE_ENV=sandbox