          "name": "ffmpeg-enable-nonfree",
          "license": "Non-Commercial",
          "reason": "Nonfree builds are not redistributable under the strict commercial-clean policy."
        },
        {
          "name": "libx264",
          "license": "GPL-2.0",
          "reason": "GPL encoder; blocked from core LGPL-only build."
        },
        {
          "name": "libx265",
          "license": "GPL-2.0",
