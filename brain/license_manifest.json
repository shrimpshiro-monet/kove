        "prefer-vp9-av1-opus-for-patent-clean-exports"
      ],
      "blockedVariants": [
        {
          "name": "ffmpeg-enable-gpl",
          "license": "GPL-2.0-or-later",
          "reason": "FFmpeg becomes GPL when GPL parts are enabled."
