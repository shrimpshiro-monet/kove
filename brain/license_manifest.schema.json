{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://monet.local/schemas/license_manifest.schema.json",
  "title": "Monet License Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "policy",
    "components"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "1.0.0"
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "allowedLicenses",
        "blockedLicenses",
        "failClosed",
        "allowIsc"
      ],
      "properties": {
        "allowedLicenses": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": [
              "MIT",
              "Apache-2.0",
              "LGPL-2.1-or-later",
              "LGPL-3.0-or-later"
            ]
          },
          "uniqueItems": true
        },
        "blockedLicenses": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "failClosed": {
          "type": "boolean",
          "const": true
        },
        "allowIsc": {
          "type": "boolean",
          "const": false
        }
      }
    },
    "components": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/component"
      }
    }
  },
  "$defs": {
    "component": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "category",
        "license",
        "commercialUse",
        "status",
        "source",
        "downloadPolicy",
        "artifacts",
        "constraints",
        "blockedVariants"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._-]*$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "category": {
          "type": "string",
          "enum": [
            "render",
            "orchestration",
            "api",
            "audio",
            "vision",
            "depth",
            "motion",
            "codec",
            "model",
            "library"
          ]
        },
        "license": {
          "type": "string",
          "minLength": 1
        },
        "commercialUse": {
          "type": "boolean"
        },
        "status": {
          "type": "string",
          "enum": [
            "approved",
            "blocked",
            "blocked-until-pinned",
            "blocked-policy-exception-required"
          ]
        },
        "source": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "type",
            "locator"
          ],
          "properties": {
            "type": {
              "type": "string",
              "enum": [
                "github",
                "pypi",
                "npm",
                "huggingface",
                "system",
                "internal"
              ]
            },
            "locator": {
              "type": "string",
              "minLength": 1
            },
            "version": {
              "type": "string"
            },
            "commit": {
              "type": "string"
            }
          }
        },
        "downloadPolicy": {
          "type": "string",
          "enum": [
            "bundled",
            "runtime-download-approved",
            "system-installed-approved",
            "blocked-until-pinned",
            "blocked"
          ]
        },
        "artifacts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/artifact"
          }
        },
        "constraints": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "blockedVariants": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/blockedVariant"
          }
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "name"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "binary",
            "source",
            "model-weight",
            "package",
            "checkpoint",
            "container-image"
          ]
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "required": {
          "type": "boolean"
        }
      }
    },
    "blockedVariant": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "reason"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "license": {
          "type": "string"
        }
      }
    }
  }
}
